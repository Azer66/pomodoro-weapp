.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  transition: background 0.5s ease;
}

.focus-mode {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
}

.break-mode {
  background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
}

.mode-selector {
  display: flex;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

.mode-btn {
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.2s ease;
}

.mode-btn.active.focus {
  background: #FF6347;
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(255, 99, 71, 0.4);
}

.mode-btn.active.break {
  background: #98D8AA;
  color: #0f2027;
  box-shadow: 0 4rpx 20rpx rgba(152, 216, 170, 0.4);
}

.timer-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0;
}

.timer-ring {
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.timer-ring.focus {
  border: 12rpx solid #FF6347;
  box-shadow: 0 0 60rpx rgba(255, 99, 71, 0.3), inset 0 0 60rpx rgba(255, 99, 71, 0.1);
}

.timer-ring.break {
  border: 12rpx solid #98D8AA;
  box-shadow: 0 0 60rpx rgba(152, 216, 170, 0.3), inset 0 0 60rpx rgba(152, 216, 170, 0.1);
}

.timer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-text {
  font-size: 120rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 4rpx;
}

.mode-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 16rpx;
  letter-spacing: 8rpx;
}

.controls {
  display: flex;
  align-items: center;
  gap: 64rpx;
  margin-top: 100rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.control-btn.secondary {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.1);
}

.control-btn.main {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #FF6347 0%, #FF8066 100%);
  box-shadow: 0 8rpx 40rpx rgba(255, 99, 71, 0.4);
}

.btn-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

.control-btn.main .btn-icon {
  font-size: 64rpx;
  color: white;
}

.control-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.pomodoro-counter {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-top: 100rpx;
}

.dots {
  display: flex;
  gap: 20rpx;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.dot.filled {
  background: #FF6347;
  box-shadow: 0 0 20rpx rgba(255, 99, 71, 0.5);
}

.dot.pulse {
  background: rgba(255, 99, 71, 0.5);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.9); }
}

.counter-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.counter-text .count {
  color: #FF6347;
  font-weight: bold;
}

.settings-btn {
  position: fixed;
  top: 40rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-btn .icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

.settings-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.settings-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.settings-panel {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.settings-overlay.show .settings-panel {
  transform: scale(1);
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.settings-header .title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
}

.setting-item {
  margin-bottom: 40rpx;
}

.setting-item .label {
  display: block;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.slider-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.slider-row slider {
  flex: 1;
}

.value {
  color: white;
  font-size: 28rpx;
  font-family: monospace;
  min-width: 140rpx;
  text-align: right;
}
